{
  "name": "controleonline/smoke-tests-playground",
  "description": "Symfony bundle for exposing browser smoke test indexes and artifacts as JSON APIs in ControleOnline projects.",
  "type": "symfony-bundle",
  "license": "MIT",
  "authors": [
    {
      "name": "Controle Online",
      "email": "ti@controleonline.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "symfony/config": "^7.1",
    "symfony/console": "^7.1",
    "symfony/dependency-injection": "^7.1",
    "symfony/framework-bundle": "^7.1",
    "symfony/process": "^7.1",
    "symfony/yaml": "^7.1"
  },
  "autoload": {
    "psr-4": {
      "ControleOnline\\SmokeTestsPlayground\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ControleOnline\\SmokeTestsPlayground\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "sort-packages": true
  }
}
