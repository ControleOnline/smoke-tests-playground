<!doctype html>
<html lang="pt">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ page_title }}</title>
    {{ include('@SmokeTestsPlayground/smoke_tests_playground/_styles.html.twig') }}
</head>
<body>
    <main
        class="shell"
        data-tests-endpoint="{{ tests_endpoint|e('html_attr') }}"
        data-run-endpoint="{{ run_endpoint|e('html_attr') }}"
        data-status-class="{{ status_class|e('html_attr') }}"
        data-status-label="{{ status_label|e('html_attr') }}"
        data-progress="{{ progress|e('html_attr') }}"
        data-message="{{ message|e('html_attr') }}"
        data-last-run-at="{{ last_run_at|default('')|e('html_attr') }}"
    >
        <section class="hero">
            <div class="hero-row">
                <div>
                    <p class="eyebrow">Smoke tests playground</p>
                    <h1>{{ page_heading }}</h1>
                    <p class="subtitle">{{ page_subtitle }}</p>
                </div>
                <div id="status-pill" class="status-pill {{ status_class }}">{{ status_label }}</div>
            </div>

            <div id="flash-message" class="message warning" style="display:none;"></div>

            <div class="controls">
                <button id="run-button" class="button primary" type="button">Rodar novos testes</button>
                <button id="reload-button" class="button secondary" type="button">Recarregar relatório</button>
            </div>
        </section>

        <section class="grid">
            <aside class="card summary">
                <h2 class="section-title">Estado público</h2>
                <div class="metric">
                    <span class="metric-label">Progresso</span>
                    <strong id="progress-value">{{ progress }}%</strong>
                </div>
                <div class="progress-track" aria-hidden="true">
                    <div id="progress-bar" class="progress-bar" style="width: {{ progress }}%;"></div>
                </div>
                <div class="stats">
                    <div class="stat">
                        <span class="metric-label">Testes</span>
                        <strong id="summary-total">{{ summary.total|default(0) }}</strong>
                    </div>
                    <div class="stat">
                        <span class="metric-label">Passaram</span>
                        <strong id="summary-passed">{{ summary.passed|default(0) }}</strong>
                    </div>
                    <div class="stat">
                        <span class="metric-label">Falharam</span>
                        <strong id="summary-failed">{{ summary.failed|default(0) }}</strong>
                    </div>
                </div>
                <p id="last-run-value" class="muted">Última execução: {{ last_run_at|default('sem registro') }}</p>
            </aside>

            <article class="card content">
                <div class="section-head">
                    <div>
                        <h2 class="section-title">Testes</h2>
                        <p class="muted">{{ headline }}</p>
                    </div>
                    <div class="message-inline" id="message-content">{{ headline }}</div>
                </div>

                <div id="tests-empty" class="empty-state">Ainda não há testes publicados.</div>
                <div id="tests-list" class="tests-list"></div>
            </article>
        </section>
    </main>

    {{ include('@SmokeTestsPlayground/smoke_tests_playground/_scripts.html.twig') }}
</body>
</html>
